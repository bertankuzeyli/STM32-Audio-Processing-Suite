#define I2S_BUFFER_SIZE         128
#define NUM_SAMPLES             32
#define SOF_WORD                0x55AA
#define EOF_BYTE                0x0A
#define BLOCK_SIZE              NUM_SAMPLES
#define NUM_STAGES              1
#define SHIFT_AMOUNT            8
/* USER CODE END PD */

