void filter_init(void)
{
    arm_fill_f32(0.0f, lpf_state, 4);
    arm_biquad_cascade_df1_init_f32(&lpf_instance, NUM_STAGES, lpf_coeffs, lpf_state);
}

__attribute__((optimize("O3")))
void process_and_send_samples_cmsis(void)
{
    int32_t* src = (int32_t*)active_buffer;

    // 1. Sadece çift indexleri kopyala (ARM offset kullanarak)
    for (int i = 0; i < NUM_SAMPLES; i++)
    {
        temp_q31_buffer[i] = src[i * 2];
    }

    // 2. ARM ile 8-bit sağa kaydırma (Q31 -> Q23)
    arm_shift_q31(temp_q31_buffer, -SHIFT_AMOUNT, temp_q31_buffer, BLOCK_SIZE);

    // 3. Q31 -> Float dönüşümü (ARM donanım FPU)
    arm_q31_to_float(temp_q31_buffer, temp_float_buffer, BLOCK_SIZE);

    // 4. LPF filtresi uygula
    arm_biquad_cascade_df1_f32(&lpf_instance, temp_float_buffer, output_buffer, BLOCK_SIZE);

    // 5. Paketi hazırla ve gönder
    usb_packet.sof = SOF_WORD;
    arm_copy_f32(output_buffer, usb_packet.samples, NUM_SAMPLES);
    usb_packet.eof = EOF_BYTE;

    CDC_Transmit_HS((uint8_t*)&usb_packet, sizeof(usb_packet));

    active_buffer = NULL;
}

