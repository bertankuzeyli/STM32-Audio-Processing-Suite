    if(HAL_I2S_Receive_DMA(&hi2s1, (uint16_t*)i2s_rx_buffer, I2S_BUFFER_SIZE) != HAL_OK)
    {
        Error_Handler();
    }
    /* USER CODE END 2 */

    /* USER CODE BEGIN WHILE */
    while (1)
    {
        /* USER CODE END WHILE */

        /* USER CODE BEGIN 3 */
        if (active_buffer != NULL)
        {
            process_and_send_samples_cmsis();
        }
    }
    /* USER CODE END 3 */
}

